# =============================================================================
# OneBerry DevKit 手动发布配置
# =============================================================================
# 复制此文件为 .env 并填写实际值:
#   cp .env.example .env
#
# ⚠️  .env 已在 .gitignore 中，不会被提交到仓库
# =============================================================================

# GitHub Personal Access Token (需要 Contents 权限，用于下载 Release 产物)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitLab API Token (需要 api 权限，用于上传 Package Registry + push update.json)
GITLAB_API_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ── 以下通常不需要修改 ──

# GitHub 仓库路径
GITHUB_REPO=Maroet/oneberry-devkit

# GitLab 地址
GITLAB_HOST=https://gitlab.oneberry.cc:2083

# GitLab 项目路径
GITLAB_PROJECT_PATH=hongmei-z/oneberry-devkit

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OneBerry DevKit",
  "version": "0.1.0",
  "identifier": "com.oneberry.devkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OneBerry DevKit",
        "width": 960,
        "height": 680,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "OneBerry DevKit"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/kubectl",
      "binaries/ktctl"
    ],
    "resources": [
      "resources/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gitlab.oneberry.cc:2083/hongmei-z/oneberry-devkit/-/raw/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxNkMzM0I5RUNDMEI1N0UKUldSK3RjRHN1VE5zVWNSTGs3dXptMThwRzhtcllNdTdPNkJxZ0ZpRFlQbUM3NmE0UEFidjBXNm4K"
    }
  }
}

{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    },
    "notification:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "core:event:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/kubectl",
          "sidecar": true,
          "args": true
        },
        {
          "name": "binaries/ktctl",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
